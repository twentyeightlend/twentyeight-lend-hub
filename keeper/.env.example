# --- twentyeight-lend keeper config (copy to .env, fill in, never commit secrets) ---
RPC_URL=https://rpc.hyperliquid.xyz/evm
# Keeper EOA private key (0x...). Use a low-privilege hot key funded only with gas (HYPE).
# It must be set as the market `voteKeeper` / engine caller. NEVER commit this.
KEEPER_PK=0x

# Deployed addresses (from the Deploy script output)
LENDING_CORE=0x
NEST_ADAPTER=0x
KITTEN_ADAPTER=0x
SELF_REPAY_ENGINE=0x
WVENEST_MARKET=0x
HAIRCUT_ORACLE=0x
# DEX voters (read poolVoteLength to detect positions needing (re)voting)
NEST_VOTER=0x566bdc5444fd5fe5d93ec379Bd66eC861ddbA901
KITTEN_VOTER=0xb7F7053F7e6c210e6777D5BA758E4b3ECa6C88A0
# pools the keeper votes new/idle deposits to (comma-separated). Empty => skip re-vote (warns).
# Production: compute the optimal (highest-fee) allocation per epoch instead of a static set.
VOTE_POOLS_NEST=
VOTE_POOLS_KITTEN=
# USE_OPTIMAL_VOTE=1 ignores the static lists above and votes the top-fee pools computed live
USE_OPTIMAL_VOTE=0
OPTIMAL_TOP_N=5
# reward tokens the self-repay engine should swap to USDC (comma). Default WHYPE. Each gets a
# direct Algebra path; the engine enforces an oracle minOut and skips unpriced tokens.
SELF_REPAY_TOKENS=0x5555555555555555555555555555555555555555

# Market params (must match the deployed markets exactly; hash must equal the on-chain Id)
USDC=0xb88339CB7199b77E23DB6E890353E22632Ba630f
# NEST market: loanToken=USDC, veAdapter=NEST_ADAPTER, oracle=0, irm=0, lltv=0
# KITTEN market: loanToken=USDC, veAdapter=KITTEN_ADAPTER, oracle=0, irm=0, lltv=0

# Pyth (pull-based) — push fresh prices before oracle-dependent actions
PYTH=0xe9d69CdD6Fe41e7B621B4A688C5D1a68cB5c8ADc
HERMES_URL=https://hermes.pyth.network
# comma-separated Pyth feed ids to keep fresh (HYPE, USDC, USDT, ETH)
PYTH_FEED_IDS=0x4279e31cc369bbcc2faf022b382b080e32a8e689ff20fbc530d2a603eb6cd98b,0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a,0x2b89b9dc8fdf9f34709a5b106b472f0f39bb6ca9ce04b0fd7f2e971688e2e53b,0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace

# --- monitor.mjs (read-only watchdog; no key needed) ---
# Slack/Discord-compatible incoming webhook for alerts (optional; logs to console if empty)
ALERT_WEBHOOK=
# proxies to watch for malicious upgrades (comma). If empty, falls back to VE_NEST,VE_KITTEN,*_VOTER below.
WATCH_PROXIES=
VE_NEST=
VE_KITTEN=
ALERT_COOLDOWN_SECONDS=3600   # re-page a persistent condition at most once per window
UTIL_ALERT_BPS=9500           # alert when market utilization (borrow/supply) >= 95%
KEEPER_STALE_SECONDS=900      # alert if keeper-state.json lastBlock hasn't advanced in this long
KEEPER_STATE_FILE=./keeper-state.json
MONITOR_STATE_FILE=./monitor-state.json

# Behaviour
DRY_RUN=1            # 1 = log intended txs, never send (default safe)
POLL_SECONDS=60
START_BLOCK=0        # block to begin event scanning from (deploy block)
MIN_SELF_REPAY_USDC=5   # skip self-repay below this harvested value (gas not worth it)
STATE_FILE=./keeper-state.json
